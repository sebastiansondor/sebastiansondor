		<meta property="og:image" content="https://sebastiansondor.com/screen.png" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Sebastián Sondor — Desarrollador Fullstack" />
		<meta name="twitter:description" content="Portfolio de Sebastián Sondor, desarrollador fullstack en Madrid. Java, Spring Boot, React Native y TypeScript." />
		<meta name="twitter:image" content="https://sebastiansondor.com/screen.png" />

		<title>Sebastián Sondor — Desarrollador Fullstack</title>
	</head>
